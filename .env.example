# Copy this file to .env and fill in real credentials locally.
# Shell environment variables take precedence over values in .env.
# DevTeamOS 当前默认通过 OpenHands CLI 执行真实任务。
# 当前仓库默认接 MiniMax Coding Plan，并在运行时自动映射成 OpenHands headless mode 所需的 LLM_* 环境变量。
# Never commit real API keys or other secrets.

# ===== Required for MiniMax Coding Plan =====
MINIMAX_API_KEY=__FILL_IN_YOUR_MINIMAX_API_KEY__

# ===== Optional overrides =====
# 默认会映射成 OpenHands 可识别的 openai/MiniMax-M2.7。
MINIMAX_MODEL=MiniMax-M2.7
# 默认使用 MiniMax 官方 OpenAI-compatible endpoint。
MINIMAX_BASE_URL=https://api.minimaxi.com/v1

# Use when OpenHands is installed in a non-default location.
# DEVTEAM_OPENHANDS_COMMAND=/absolute/path/to/openhands
# Use when you want to override the workspace-local OpenHands HOME directory.
# DEVTEAM_OPENHANDS_HOME=/absolute/path/to/openhands-home
