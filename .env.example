# Copy this file to .env and fill in real credentials locally.
# Shell environment variables take precedence over values in .env.
# Choose ONE provider configuration group below based on the provider you use.
# Never commit real API keys or other secrets.

# ===== OpenAI example =====
# Uncomment this group if you use OpenAI.
# DEVTEAM_LLM_PROVIDER=openai
# DEVTEAM_LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=your_openai_api_key_here

# ===== MiniMax Quickstart example =====
# Uncomment this group if you use MiniMax.
# Official Quickstart-style settings for the Anthropic-compatible endpoint.
# DEVTEAM_LLM_PROVIDER=minimax
# DEVTEAM_LLM_MODEL=MiniMax-M2.7
# ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
# ANTHROPIC_API_KEY=your_minimax_api_key_here
